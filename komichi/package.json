{
  "name": "@shunsuke0429/komichi",
  "version": "0.1.0",
  "description": "Developer-friendly lightweight TypeScript web framework with route guidance and request trails.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx examples/basic.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx --test tests/**/*.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "typescript",
    "web-framework",
    "http",
    "router",
    "nodejs",
    "developer-tools"
  ],
  "author": "Shunsuke Urabe",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}